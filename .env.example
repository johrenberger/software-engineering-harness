# Slice 13 — runtime configuration.
#
# Copy this file to `.env` and fill in the values before running
# `harness-telegram-bot` or `harness-dashboard`.

# Telegram bot token from @BotFather (REQUIRED).
TELEGRAM_BOT_TOKEN=

# Comma-separated list of chat ids permitted to invoke commands.
# Empty list = reject ALL (fail-secure, slice 11 invariant).
TELEGRAM_ALLOWED_CHAT_IDS=

# Telegram runtime mode: "polling" (default) or "webhook".
TELEGRAM_MODE=polling

# Dashboard server bind address (loopback only — public bind is rejected).
HARNESS_DASHBOARD_HOST=127.0.0.1
HARNESS_DASHBOARD_PORT=8765

# GitHub PAT used by the slice-9 delivery subsystem.
GITHUB_TOKEN=

# OpenClaw workspace (default ~/.openclaw).
OPENCLAW_HOME=~/.openclaw
